# Use the official Rasa SDK image
FROM rasa/rasa-sdk:3.6.2

# Switch to root to install custom Python dependencies
USER root

WORKDIR /app

# Copy custom actions
COPY actions /app/actions

# Install requests via pip without caching to save space
RUN pip install --no-cache-dir requests

# Switch back to non-root
USER 1001

EXPOSE 5055

# Run custom actions
CMD ["start", "--actions", "actions"]

