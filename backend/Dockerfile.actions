# Rasa Action Server
FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY . .

# Install rasa-sdk and requests
RUN pip install --upgrade pip && pip install rasa-sdk requests

# Expose action server port
EXPOSE 5055

# Start the action server
CMD ["rasa", "run", "actions", "--port", "5055", "--interface", "0.0.0.0", "--auto-reload"]
